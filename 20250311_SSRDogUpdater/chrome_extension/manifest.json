{
  "manifest_version": 3,
  "name": "SSR Dog Updater",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "pageCapture", "downloads", "alarms", "debugger", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.ssrdog.com/*"],
      "js": ["mainworld.js"],
   	  "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.ssrdog.com/*"],
      "js": ["isolated.js"],
   	  "all_frames": true,
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}